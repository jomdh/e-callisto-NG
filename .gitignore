# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Env / secrets
.env
*.local

# OS
.DS_Store

# Scratch
.temp/

# Legacy reverse-engineering reference (downloads, extracted source, analysis).
# Local-only; not part of the NG repo.
legacy/

# Planning, sprint logs, milestone plans, changelog, parity audit, research --
# maintainer-local methodology, kept on the computer, not pushed. EXCEPT
# docs/architecture/ (ADRs): third-party driver authors build against the
# plugin contracts, so the architecture-decision record ships.
docs/*
!docs/architecture/
**/.DS_Store

# stray SQLite DBs -- the station creates its own
*.db
*.db-journal
