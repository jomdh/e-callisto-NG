#!/usr/bin/make -f
# Build the ecallisto-ng package: install into /opt/ecallisto-ng with a venv.

export DH_VERBOSE = 1
APPDIR = debian/ecallisto-ng/opt/ecallisto-ng

%:
	dh $@ --with python3

override_dh_auto_build:
	# the venv is created in postinst on the target (arch-correct wheels)

override_dh_auto_install:
	mkdir -p $(APPDIR)
	cp -r src pyproject.toml README.md packaging $(APPDIR)/
	install -D -m0644 packaging/systemd/ecallisto-web.service \
	    debian/ecallisto-ng/lib/systemd/system/ecallisto-web.service

override_dh_auto_test:
	# tests run in CI, not at package build time
