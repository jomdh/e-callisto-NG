# e-Callisto NG -- example environment. Copy to .env and fill in.
# NEVER commit .env. Secrets are read via settings, not hardcoded.
# scripts/install.sh generates a .env with a random secret key for you.

# Data + config locations
#   production: /var/lib/callisto (needs sudo to create)
#   quick test: a repo-local ./data dir (install.sh defaults to this)
ECALLISTO_DATA_DIR=/var/lib/callisto
ECALLISTO_CONFIG_DIR=/etc/callisto

# Database (SQLite, single station)
ECALLISTO_DB_URL=sqlite:///./ecallisto.db

# Secret key for sessions/credential encryption. MUST be a random value on a
# real station -- generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ECALLISTO_SECRET_KEY=dev-insecure-change-me

# Web. Bind 0.0.0.0 so the station is reachable over the LAN/VPN; put it behind
# TLS for any public exposure (the Access page can generate a Caddy config).
ECALLISTO_BIND=0.0.0.0
ECALLISTO_PORT=8000

# Time source: system (OS clock + chrony) or gps
ECALLISTO_TIME_SOURCE=system
