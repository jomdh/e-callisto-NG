# e-Callisto NG -- example environment. Copy to .env and fill in.
# NEVER commit .env. Secrets are read via settings, not hardcoded.

# Data + config locations (defaults shown)
ECALLISTO_DATA_DIR=/var/lib/callisto
ECALLISTO_CONFIG_DIR=/etc/callisto

# Web (set in the install wizard; no default admin credentials exist)
ECALLISTO_BIND=127.0.0.1
ECALLISTO_PORT=8000
